{
  "$schema": "https://opencode.ai/config.json",
  "command": {
    "review-my-code": {
      "description": "Interactive code review of selected code",
      "template": "Interactive Code Review",
      "prompt": "Load the `code-review` skill and perform a comprehensive code review. For each issue found, list: file path, line number, issue type (Security/Performance/Quality/Maintainability), severity, description, and suggested fix. After listing all issues, ask me which ones I want you to fix."
    },
    "test": {
      "description": "Generate unit tests",
      "template": "Unit Test Generation",
      "prompt": "Load the `testing` skill. Use the `testsprite` MCP if available to automatically generate tests. Otherwise, generate comprehensive unit tests following the skill guidelines. Include tests for happy path, edge cases, and error scenarios."
    },
    "refactor": {
      "description": "Suggest refactoring improvements",
      "template": "Code Refactoring",
      "prompt": "Load the `refactoring` skill and analyze this code. Identify code smells, suggest improvements, and explain the reasoning. Focus on reducing complexity and applying SOLID principles."
    },
    "explain": {
      "description": "Explain code in detail",
      "template": "Code Explanation",
      "prompt": "Explain this code in detail. Cover: what it does, how it works, why it might have been implemented this way, and any potential issues or improvements."
    },
    "optimize": {
      "description": "Optimize code for performance",
      "template": "Performance Optimization",
      "prompt": "Load the `performance` skill and analyze this code for optimization opportunities. Identify bottlenecks, suggest improvements with before/after comparisons, and estimate the performance impact."
    },
    "security": {
      "description": "Security audit",
      "template": "Security Audit",
      "prompt": "Load the `security-audit` skill and perform a comprehensive security audit. Check for all vulnerabilities in the checklist, classify findings by severity (Critical/High/Medium/Low), and provide remediation steps."
    },
    "document": {
      "description": "Generate documentation",
      "template": "Documentation Generation",
      "prompt": "Load the `documentation` skill and generate comprehensive documentation in English. Follow the patterns and templates from the skill for README, API docs, or JSDoc/TSDoc as appropriate."
    },
    "commit": {
      "description": "Create atomic semantic commits",
      "template": "Semantic Commit",
      "prompt": "Load the `git-workflow` skill. Analyze all staged and unstaged changes. Create ATOMIC commits following Conventional Commits specification. Rules: 1) Group related changes by feature/fix/refactor - DO NOT commit everything at once. 2) Each commit should represent ONE logical change. 3) All commit messages MUST be in English using imperative mood. 4) If a prefix argument is provided (e.g., '/commit JIRA-123'), prepend it to each commit message as '{prefix}: type(scope): description'. 5) If no prefix is provided, use standard format 'type(scope): description'. 6) Stage and commit each group separately. 7) Show a summary of all commits created."
    },
    "pr": {
      "description": "Generate PR description",
      "template": "PR Description",
      "prompt": "Load the `git-workflow` skill and generate a comprehensive Pull Request description in English. Include: summary of changes, motivation, testing done, and any breaking changes or migration notes. Follow the PR guidelines from the skill."
    },
    "debug": {
      "description": "Help debug an issue",
      "template": "Debug Help",
      "prompt": "Load the `debugging` skill and help me debug this issue. Follow the systematic debugging process: reproduce, isolate, identify root cause, fix, verify. Consider common bug patterns from the skill."
    },
    "types": {
      "description": "Add/improve TypeScript types",
      "template": "TypeScript Typing",
      "prompt": "Load the `typescript` skill and analyze this code. Add or improve TypeScript types following strict typing guidelines. Use proper type guards, utility types, and avoid 'any'. Follow all patterns from the skill."
    },
    "scrape": {
      "description": "Scrape content from websites",
      "template": "Web Scraping",
      "prompt": "Load the `web-scraping` skill and use the `firecrawl` MCP to extract content. Determine the best tool (scrape, batch_scrape, map, crawl, search, or extract) based on the task. Follow the guidelines from the skill."
    },
    "plan": {
      "description": "Create implementation plan",
      "template": "Planning",
      "prompt": "Load the `writing-plans` skill and create a detailed implementation plan. Break down the task into clear steps with acceptance criteria."
    }
  }
}
